         # maintain the API contract, we expect a missing trust to raise a 404
@@ -214,6 +235,7 @@ class TrustResource(ks_flask.ResourceBase):
                                   target_attr=target)
         else:
             ENFORCER.enforce_call(action='identity:list_trusts')
+        _check_application_credential()
 
         trusts = []
 
